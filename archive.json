      "assignees": [],
      "labels": [],
      "body": "From the the protocol doc, section 6 [1]\r\n\r\n[1]: https://datatracker.ietf.org/doc/html/draft-ietf-privacypass-protocol-08#name-issuance-protocol-for-publi",
      "createdAt": "2023-02-07T22:59:37Z",
      "updatedAt": "2023-02-10T18:57:24Z",
